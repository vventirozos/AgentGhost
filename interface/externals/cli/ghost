# --- small formatting helpers ---------------------------------------------

def _ago(ts: float | None) -> str:
    """'42s ago' / '3m ago' / '5h ago' / '2d ago' from an epoch float."""
    if not ts:
        return "—"
    d = max(0.0, time.time() - float(ts))
    if d < 90:
        return f"{d:.0f}s ago"
    if d < 5400:
        return f"{d / 60:.0f}m ago"
    if d < 129600:
        return f"{d / 3600:.0f}h ago"
    return f"{d / 86400:.0f}d ago"


def _dur(seconds: float | None) -> str:
    if seconds is None:
        return "—"
    s = int(seconds)
    if s < 90:
        return f"{s}s"
    if s < 5400:
        return f"{s // 60}m {s % 60}s"
    if s < 129600:
        return f"{s // 3600}h {s % 3600 // 60}m"
    return f"{s // 86400}d {s % 86400 // 3600}h"


def _trim(text: Any, width: int) -> str:
    text = " ".join(str(text or "").split())
    return text if len(text) <= width else text[: width - 1] + "…"


def _table(headers: list[str], rows: list[list[str]]) -> None:
    """Muted-header, borderless table. Cells are plain text (never parsed
    as rich markup — titles/previews can contain anything)."""
    if not rows:
        return
    t = Table(box=None, header_style="mute", pad_edge=False,
              padding=(0, 2, 0, 0))
    for h in headers:
        t.add_column(h)
    for r in rows:
        t.add_row(*[Text(str(c)) for c in r])
    console.print(t)


def _reply_renderable(text: str) -> Group:
    """The ghost's reply as it renders in the transcript: label + Markdown."""
    return Group(Text("👻", style="ghost"), Markdown(text, code_theme=CODE_THEME))


