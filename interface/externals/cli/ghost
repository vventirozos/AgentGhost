def _default_key() -> str:
    """Resolve the API key: GHOST_API_KEY env, then the canonical secret
    file shared with the agent/interface/Slack-bot launchers (2026-07-13 —
    the agent now enforces a real key; the old ghost-secret-123 fallback is
    the publicly-known retired default and no longer works)."""
    env = (os.environ.get("GHOST_API_KEY") or "").strip()
    if env:                      # blank/whitespace env must not shadow the file
        return env
    try:
        return (Path.home() / "Data/AI/.ghost_api_key").read_text().strip()
    except OSError:
        return ""


