# Ghost Agent Slack bot — configuration template.
# Copy to .env (same directory), fill in, then: chmod 600 .env
# run.sh sources this file with set -a, so values with spaces are fine
# (quote them). NEVER commit the real .env — it carries live tokens.

# --- Slack app credentials (required) --------------------------------------
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_APP_TOKEN=xapp-REPLACE-ME

# --- Owner lock (required — the bot refuses to start unlocked) --------------
# Your Slack member ID: profile → ⋯ → "Copy member ID" (looks like U0123ABCDEF).
GHOST_SLACK_OWNER=U-REPLACE-ME
# ...or resolve it from your Slack email instead (needs users:read.email scope):
# GHOST_SLACK_OWNER_EMAIL=you@example.com

# --- Agent connection (required) --------------------------------------------
# Must MATCH the agent's key. Since 2026-07-13 prod ENFORCES a real key —
# copy the value from the canonical secret file on eva
# (~/Data/AI/.ghost_api_key), shared by the agent/interface/CLI launchers.
# An explicitly EMPTY value (GHOST_API_KEY=) is only valid against an agent
# running with auth disabled (--api-key ''). Do NOT pad with a space —
# whitespace becomes an illegal HTTP header value.
GHOST_API_KEY=REPLACE-ME

# --- Optional ----------------------------------------------------------------
# GHOST_API_URL=http://localhost:8000/api/chat
# Notification destination: channel id (C…) or user id (U…); default = a DM
# to the owner; "off" disables the poller.
# GHOST_NOTIFY_SLACK_CHANNEL=
# GHOST_NOTIFY_POLL_SECONDS=30
# Agent pretty-log stream for the live status updates:
# GHOST_AGENT_LOG=/Users/vasilis/Data/AI/Logs/ghost-agent.log
# Python override (default: the agent venv, which has slack_bolt/httpx):
# GHOST_BOT_PYTHON=/Users/vasilis/Data/AI/.agent.venv/bin/python
