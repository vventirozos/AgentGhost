<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Ghost Agent Slack bot (owner-locked) — launchd supervisor.
         Install:  cp <this file> ~/Library/LaunchAgents/
                   launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.local.ghost-slackbot.plist
         Secrets live in run.sh's sibling .env (chmod 600), NOT here —
         see .env.example. KeepAlive matches the prod agent's ops model:
         a plain kill of the bot process = restart (deploy); to actually
         stop it, bootout the job. -->
    <key>Label</key>
    <string>com.local.ghost-slackbot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/vasilis/Data/AI/Agent/interface/externals/slack_bot/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/vasilis/Data/AI/Agent/interface/externals/slack_bot</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- A misconfigured launch (missing .env) exits 1 immediately; without
         a throttle launchd would tight-loop the pre-flight failure. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/vasilis/Data/AI/Logs/ghost-slack-bot.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/vasilis/Data/AI/Logs/ghost-slack-bot.err</string>
</dict>
</plist>
